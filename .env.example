# Copy to .env and fill in. Never commit .env with real secrets.
#
# This server loads, in order:  <parent-of-server>/.env  then  server/.env
# (paths are fixed to the project layout, not to the shell "current directory").
# Put working LLM_* values in `server/.env` so Cursor / npm always match your
# other apps that use the same API.

# Server
PORT=3000

# LLM (OpenAI-compatible chat completions)
# For official OpenAI: base URL is often https://api.openai.com/v1
# For other providers, use their documented base URL including /v1 if required.
# If you see "Service temporarily unavailable" or HTTP 503: upstream is busy/down — retry later,
# check provider status + quota, and ensure LLM_BASE_URL points at the API (not the website HTML).
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# Optional: cap output size (input + output = context). Level3 returns a long JSON
# book — if you see HTTP 503 while short chats work in other apps, set e.g.:
# LLM_MAX_TOKENS=4096
# or 8192 depending on your provider and plan.

# If Level3 keeps returning HTTP 503 with the same key that works elsewhere, the
# long "reference passage" in the system prompt may be too large. Set to 1 to
# omit that block and shrink the request (slightly weaker style anchoring).
# LLM_LEVEL3_OMIT_REFERENCE=1

# Optional: request timeout in milliseconds
# LLM_TIMEOUT_MS=120000

# Image generation (SeeDream / Seedream — provider-specific base URL)
# Example (getimg): https://api.getimg.ai/v2  →  POST {base}/images/generations
# Set IMAGE_API_BASE_URL to the prefix printed in your provider's docs (no trailing slash).
IMAGE_API_BASE_URL=
IMAGE_API_KEY=
IMAGE_MODEL=seedream-5-0-lite
# IMAGE_ASPECT_RATIO=4:3
# IMAGE_RESOLUTION=2K
# IMAGE_OUTPUT_FORMAT=jpeg
